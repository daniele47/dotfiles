#!/bin/bash

set -e

### CUSTOMIZABLE ###
export AUTOSAVER_HOME="" # set the home directory for the autosaver binary
export AUTOSAVER_ROOT="" # set the root directory for the autosaver binary

### DO NOT EDIT ###
# setup defaults for all environment variables
[[ -z "$AUTOSAVER_HOME" ]] && AUTOSAVER_HOME="$HOME"                                        # use the user home directory
[[ -z "$AUTOSAVER_ROOT" ]] && AUTOSAVER_ROOT="$(dirname "$(realpath "${BASH_SOURCE[0]}")")" # use this script directory as the autosaver root directory

# other useful variables
GITHUB_REPO="daniele47/autosaver"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/autosaver"
PLATFORM="$(uname -s)"
ARCHITECTURE="$(uname -m)"
BINARY_NAME=""
BIN_EXTENSION=""
BIN_DOWNLOAD_URL=""
BIN_PATH=""

# get platform / os dependent variables populated
case "$PLATFORM" in
Linux)
    BIN_EXTENSION="tar.gz"
    case "$ARCHITECTURE" in
    armv7l) BINARY_NAME="autosaver-armv7-unknown-linux-musleabihf" ;;
    aarch64) BINARY_NAME="autosaver-aarch64-unknown-linux-musl" ;;
    x86_64) BINARY_NAME="autosaver-x86_64-unknown-linux-musl" ;;
    *) echo "$PLATFORM with $ARCHITECTURE is not supported" && exit 1 ;;
    esac
    ;;
*) echo "$PLATFORM is not supported" && exit 1 ;;
esac
BIN_PATH="$CACHE_DIR/autosaver"
BIN_PATH_ARCHIVE="$BIN_PATH.$BIN_EXTENSION"
BIN_DOWNLOAD_URL="https://github.com/$GITHUB_REPO/releases/latest/download/$BINARY_NAME.$BIN_EXTENSION"

# try to download binary if missing
if [[ ! -f "$BIN_PATH" ]]; then
    echo -n "Binary file is missing. Do you want to try and download from github? [y/n] "
    read -r answer
    if [[ "$answer" != "y" ]]; then echo "Exiting..." && exit 1; fi

    # download binary
    mkdir -p "$CACHE_DIR"
    if command -v curl &>/dev/null; then
        echo "Downloading binary using curl..."
        curl -L --fail --show-error --progress-bar -o "$BIN_PATH_ARCHIVE" "$BIN_DOWNLOAD_URL"
    elif command -v wget &>/dev/null; then
        echo "Downloading binary using wget..."
        wget --quiet --show-progress --output-document="$BIN_PATH_ARCHIVE" "$BIN_DOWNLOAD_URL"
    else
        echo "Could not download the binary. Exiting..." && exit 1
    fi

    # decompressing binary
    echo "Binary successfully downloaded! Proceeding to decompress the binary..."
    case "$PLATFORM" in
    Linux) tar xzf "$BIN_PATH_ARCHIVE" -C "$CACHE_DIR" ;;
    *) echo "$PLATFORM is not supported" && exit 1 ;;
    esac

    # deleting temporary files
    echo "Binary successfully decompressed! Proceeding to cleanup archive..."
    rm "$BIN_PATH_ARCHIVE"

    # show downloaded binary version
    echo -n "Binary download finished! The downloaded version was: "
    "$BIN_PATH" "--version"

    # separator to distinguish download output from actual command output
    echo -e "--------------------------------------------------------------------------------\n"
fi

# run binary
"$BIN_PATH" "$@"
