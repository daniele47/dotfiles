#!/bin/bash

### WRAPPER BASH SCRIPT TO DOWNLOAD AND RUN RUST BINARY ###

set -e

# setup defaults for all environment variables
export AUTOSAVER_HOME="${AUTOSAVER_HOME:-$HOME}"
export AUTOSAVER_ROOT="${AUTOSAVER_ROOT:-$(dirname "$(realpath "${BASH_SOURCE[0]}")")}"

# variables
BIN_PATH_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/autosaver"
BIN_PATH="$BIN_PATH_DIR/autosaver"
SCRIPTS_URL="https://raw.githubusercontent.com/daniele47/autosaver/refs/heads/main/scripts"

function download_url() {
    local url="$1"
    local output="$2"
    if command -v curl &>/dev/null; then
        curl -L --fail --show-error --progress-bar --output "$output" "$url"
    elif command -v wget &>/dev/null; then
        wget --no-verbose --show-progress --output-document="$output" "$url"
    else
        echo "ERROR: Neither curl nor wget found. Please install one." >&2
        return 1
    fi
}

# update/uninstall
if [[ -v UNINSTALL ]]; then
    echo "Downloading and running uninstall script..."
    TMP_FILE="$(mktemp)"
    download_url "$SCRIPTS_URL/uninstall.sh" "$TMP_FILE"
    bash "$TMP_FILE"
    rm "$TMP_FILE"
    echo -e "--------------------------------------------------------------------------------\n"
fi
if [[ ! -f "$BIN_PATH" && ! -v UNINSTALL || -v INSTALL ]]; then
    echo "Downloading and running install script..."
    TMP_FILE="$(mktemp)"
    download_url "$SCRIPTS_URL/install.sh" "$TMP_FILE"
    bash "$TMP_FILE"
    rm "$TMP_FILE"
    echo -e "--------------------------------------------------------------------------------\n"
fi

# run binary
"$BIN_PATH" "$@"
